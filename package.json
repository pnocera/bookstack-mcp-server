{
  "name": "bookstack-mcp-server",
  "version": "2.0.1",
  "description": "MCP server providing comprehensive access to BookStack knowledge management system",
  "type": "module",
  "main": "src/server.ts",
  "module": "src/server.ts",
  "scripts": {
    "start": "bun run src/server.ts",
    "dev": "bun --watch src/server.ts",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage",
    "test:integration": "RUN_INTEGRATION=1 bun test tests/integration",
    "integration:up": "bun run scripts/integration-up.ts",
    "typecheck": "tsc --noEmit",
    "build": "bun build ./src/server.ts --target bun --outdir ./dist",
    "clean": "rm -rf dist",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "prepublishOnly": "bun run typecheck",
    "docker:build": "docker build -t bookstack-mcp-server .",
    "docker:run": "docker run --rm -p 3000:3000 --env-file .env bookstack-mcp-server"
  },
  "keywords": [
    "mcp",
    "bookstack",
    "api",
    "server",
    "claude",
    "context",
    "documentation",
    "bun"
  ],
  "author": "BookStack MCP Integration",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "axios": "1.18.1",
    "dotenv": "17.4.2",
    "express": "5.2.1",
    "winston": "3.19.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.4",
    "@types/bun": "1.3.14",
    "@types/express": "5.0.6",
    "@types/node": "26.1.1",
    "ajv": "8.20.0",
    "typescript": "7.0.2"
  },
  "engines": {
    "bun": ">=1.1.0"
  },
  "bin": {
    "bookstack-mcp-server": "src/server.ts"
  },
  "files": [
    "src/**/*",
    "tsconfig.json",
    "README.md",
    ".env.example"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/pnocera/bookstack-mcp-server.git"
  },
  "bugs": {
    "url": "https://github.com/pnocera/bookstack-mcp-server/issues"
  },
  "homepage": "https://github.com/pnocera/bookstack-mcp-server#readme"
}
